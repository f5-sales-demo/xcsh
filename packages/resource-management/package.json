{
	"type": "module",
	"name": "@f5xc-salesdemos/pi-resource-management",
	"version": "19.51.1",
	"description": "Shared resource management for F5 XC manifest parsing, validation, diff, and CRUD operations",
	"homepage": "https://github.com/f5xc-salesdemos/xcsh",
	"author": "Robin Mordasiewicz",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/f5xc-salesdemos/xcsh.git",
		"directory": "packages/resource-management"
	},
	"bugs": {
		"url": "https://github.com/f5xc-salesdemos/xcsh/issues"
	},
	"keywords": [
		"xcsh",
		"resource-management",
		"kubectl",
		"apply",
		"manifest"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"generate-defaults": "bun run scripts/generate-defaults.ts && bun run fmt",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"yaml": "2.9.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3"
	},
	"engines": {
		"bun": ">=1.3.7"
	},
	"files": [
		"src"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"require": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts",
			"require": "./src/*.ts"
		},
		"./*.js": "./src/*.ts"
	}
}
